{
    "name": "envey",
    "version": "3.0.1",
    "description": "Type-safe configuration schemas for Node.js",
    "keywords": [
        "configuration",
        "config",
        "schema",
        "validation",
        "zod",
        "env",
        "environment",
        "node",
        "nodejs"
    ],
    "homepage": "https://github.com/samialdury/envey#readme",
    "bugs": {
        "url": "https://github.com/samialdury/envey/issues"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/samialdury/envey.git"
    },
    "license": "MIT",
    "author": "Sami Al-Dury",
    "type": "module",
    "exports": {
        ".": {
            "import": {
                "types": "./dist/index.d.ts",
                "default": "./dist/index.js"
            },
            "require": {
                "types": "./dist/index.d.cts",
                "default": "./dist/index.cjs"
            }
        },
        "./package.json": "./package.json"
    },
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "files": [
        "./dist",
        "./src"
    ],
    "scripts": {
        "build": "tsup",
        "build:ci": "bun run build",
        "format": "prettier --write .",
        "format:ci": "prettier --check .",
        "lint:ci": "publint && attw --pack .",
        "publish": "tsup",
        "release": "semantic-release",
        "test": "vitest run",
        "test:ci": "bun run test:coverage",
        "test:coverage": "vitest run --coverage",
        "test:watch": "vitest watch",
        "typecheck": "tsc --noEmit"
    },
    "devDependencies": {
        "@arethetypeswrong/cli": "0.18.2",
        "@sebbo2002/semantic-release-jsr": "3.2.1",
        "@semantic-release/changelog": "6.0.3",
        "@semantic-release/git": "10.0.1",
        "@trivago/prettier-plugin-sort-imports": "6.0.2",
        "@types/node": "25.6.0",
        "@vitest/coverage-v8": "4.1.4",
        "prettier": "3.8.3",
        "prettier-plugin-packagejson": "3.0.2",
        "publint": "0.3.18",
        "semantic-release": "25.0.3",
        "tsup": "8.5.1",
        "typescript": "5.9.2",
        "vitest": "4.1.4",
        "zod": "4.3.6"
    },
    "peerDependencies": {
        "zod": "^4.0.0"
    },
    "engines": {
        "node": ">=20"
    },
    "publishConfig": {
        "access": "public",
        "provenance": true
    }
}
